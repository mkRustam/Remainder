<?xml version="1.0" encoding="utf-8"?>
<LinearLayout style="@style/ScreenBg"
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <ru.mkr.remainder.ui.views.common.NavbarView
        android:id="@+id/navbar"
        style="@style/MatchWidth" />

    <View style="@style/Separator" />

    <ScrollView style="@style/ScrollView">

        <LinearLayout
            android:id="@+id/container"
            style="@style/MatchWidth"
            android:background="@color/bg_screen"
            android:orientation="vertical"
            android:padding="@dimen/screen_padding">

            <ru.mkr.remainder.ui.views.fields.FieldInputText
                android:id="@+id/field_task_title"
                style="@style/MatchWidth" />

            <ru.mkr.remainder.ui.views.fields.FieldInputDate
                android:id="@+id/field_task_date"
                style="@style/MatchWidth" />

            <androidx.legacy.widget.Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btnEdit"
                style="@style/Button"
                android:text="@string/button_edit" />

            <Button
                android:id="@+id/btnDelete"
                style="@style/Button"
                android:text="@string/button_delete" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>